# Exemplo de variáveis de ambiente para o backend FastAPI
# Copie este arquivo para .env e ajuste os valores conforme necessário

# Caminhos do modelo e dados
MODEL_PATH=./models/xgboost_model.pkl
CSV_PATH=./data/olist_processed.csv

# Ambiente
ENVIRONMENT=development
DEBUG=True

# Servidor
HOST=0.0.0.0
PORT=8000

# CORS (separar por vírgula)
ALLOWED_ORIGINS=*

# Logging
LOG_LEVEL=INFO
