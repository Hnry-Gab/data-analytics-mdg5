# Exemplo de variáveis de ambiente para o backend FastAPI
# Copie este arquivo para .env e ajuste os valores conforme necessário

# Caminhos do modelo e dados
MODEL_PATH=./models/v5/catboost_atraso_v5.cbm
MODEL_CONFIG_PATH=./models/v5/model_config.json
CSV_PATH=./dataset/

# Ambiente
ENVIRONMENT=development
DEBUG=True

# Servidor
HOST=0.0.0.0
PORT=8000

# CORS (separar por vírgula)
ALLOWED_ORIGINS=*

# Logging
LOG_LEVEL=INFO

# --- Chatbot (OpenRouter + MCP) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=z-ai/glm-4.5-air:free
OPENROUTER_MAX_TOKENS=4096
OPENROUTER_TEMPERATURE=0.3
CHATBOT_ENABLED=true
CHATBOT_MAX_HISTORY=50
CHATBOT_MAX_TOOL_ITERATIONS=10
